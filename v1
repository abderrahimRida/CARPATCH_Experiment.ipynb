## NEW — Task 3: Retraining Cadence Simulation (Reviewer 2.2.3 / Section 6.3)

Simulates the RFLL at different retraining frequencies using the 2021–2025 temporal holdout.

**Protocol:**
- Train base model on 2020 CVEs only
- Progressively add monthly batches of 2021–2025 CVEs as "feedback"
- Evaluate after each batch at four cadence policies: weekly (4-week), monthly, quarterly, static
- Produces a Table and line chart showing F1 vs. number of retraining cycles

Directly answers the reviewer's question: *"Is weekly retraining optimal?"*


# ══════════════════════════════════════════════════════════════════════════════
# TASK 3 — Retraining Cadence Simulation
# Paper Section 6.3  |  Addresses Reviewer comment 2.2.3
# ══════════════════════════════════════════════════════════════════════════════
import numpy as np
import pandas as pd
import xgboost as xgb
import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
from sklearn.model_selection import train_test_split
from sklearn.metrics import f1_score, roc_auc_score, precision_recall_curve
from imblearn.over_sampling import SMOTE
import warnings
warnings.filterwarnings('ignore')

RANDOM_STATE = 42
FEATURES = [
    "CVSS_norm", "AC", "NEI", "EAI", "DID", "TTR",
    "CWE_cat", "days_since_patch", "language_enc", "service_tier"
]
TARGET = "exploited"

def best_threshold_fn(y_true, y_prob):
    prec, rec, thresholds = precision_recall_curve(y_true, y_prob)
    f1s = 2 * prec * rec / np.where((prec + rec) == 0, 1, (prec + rec))
    idx = np.argmax(f1s)
    return float(thresholds[min(idx, len(thresholds) - 1)])

def eval_f1_auc(model, X_t, y_t):
    probs = model.predict_proba(X_t)[:, 1]
    thr   = best_threshold_fn(y_t, probs)
    preds = (probs >= thr).astype(int)
    return (
        round(f1_score(y_t, preds, zero_division=0), 4),
        round(roc_auc_score(y_t, probs), 4)
    )

# ── 1. Prepare data with year column
df_cadence = df_nvd[FEATURES + [TARGET, "pub_date"]].dropna().copy()
df_cadence["year"]  = pd.to_datetime(df_cadence["pub_date"], errors="coerce").dt.year
df_cadence["month"] = pd.to_datetime(df_cadence["pub_date"], errors="coerce").dt.to_period("M")

# ── 2. Base model: train on 2020 only
train_base  = df_cadence[df_cadence["year"] == 2020]
holdout_all = df_cadence[df_cadence["year"] >= 2021]

print(f"Base training set (2020)  : {len(train_base):,} records, "
      f"{train_base[TARGET].sum():,} positives")
print(f"Temporal holdout (2021+)  : {len(holdout_all):,} records, "
      f"{holdout_all[TARGET].sum():,} positives")

if train_base[TARGET].sum() < 10 or holdout_all[TARGET].sum() < 10:
    print("⚠️ Not enough positives for cadence simulation with this dataset size.")
    print("   If running on a subset, the full 143,693-record dataset is needed.")
    raise SystemExit(0)

X_base = train_base[FEATURES].values
y_base = train_base[TARGET].values

sm0 = SMOTE(random_state=RANDOM_STATE)
X_sm0, y_sm0 = sm0.fit_resample(X_base, y_base)

scale0 = int((y_base == 0).sum() / max((y_base == 1).sum(), 1))

# ── 3. Holdout test set = last 6 months of data (fixed evaluation target)
last_months = sorted(holdout_all["month"].unique())
eval_months  = last_months[-6:]
feedback_months = [m for m in last_months if m not in eval_months]

test_set  = holdout_all[holdout_all["month"].isin(eval_months)]
feedback_pool = holdout_all[holdout_all["month"].isin(feedback_months)].sort_values("month")

X_eval = test_set[FEATURES].values
y_eval = test_set[TARGET].values

print(f"\nFixed evaluation set (last 6 months): {len(test_set):,} records, "
      f"{y_eval.sum():,} positives")
print(f"Feedback pool : {len(feedback_pool):,} records across "
      f"{len(feedback_months)} months")

if y_eval.sum() < 5:
    print("⚠️ Too few positives in eval set — need full dataset.")
    raise SystemExit(0)

# ── 4. Train base model
xgb_base = xgb.XGBClassifier(
    max_depth=10, learning_rate=0.05, n_estimators=300,
    min_child_weight=1, subsample=0.8, colsample_bytree=0.8,
    scale_pos_weight=scale0, eval_metric="logloss",
    random_state=RANDOM_STATE, verbosity=0,
)
xgb_base.fit(X_sm0, y_sm0)
base_f1, base_auc = eval_f1_auc(xgb_base, X_eval, y_eval)
print(f"\nBase model (2020 only) — F1: {base_f1:.4f} | AUC: {base_auc:.4f}")

# ── 5. Simulate cadence policies
#    Group feedback_pool by month, then accumulate:
#    - Static:    never retrain  (baseline)
#    - Quarterly: retrain every 3 months of feedback
#    - Monthly:   retrain every 1 month of feedback
#    - Weekly:    retrain every ~0.25 months (approx: every month, 4 mini-batches)

def retrain(X_accumulated, y_accumulated, X_sm_init, y_sm_init, scale):
    if y_accumulated.sum() < 3:
        return None
    X_aug = np.vstack([X_sm_init, X_accumulated])
    y_aug = np.concatenate([y_sm_init, y_accumulated])
    m = xgb.XGBClassifier(
        max_depth=10, learning_rate=0.05, n_estimators=300,
        min_child_weight=1, subsample=0.8, colsample_bytree=0.8,
        scale_pos_weight=scale, eval_metric="logloss",
        random_state=RANDOM_STATE, verbosity=0,
    )
    m.fit(X_aug, y_aug)
    return m

# Group feedback by month
monthly_groups = []
for m in feedback_months:
    batch = feedback_pool[feedback_pool["month"] == m]
    monthly_groups.append((str(m), batch[FEATURES].values, batch[TARGET].values))

cadence_results = {"Month": [], "Static": [], "Quarterly": [], "Monthly": [], "Weekly": []}
current_models  = {"Static": xgb_base, "Quarterly": xgb_base,
                   "Monthly": xgb_base, "Weekly": xgb_base}

X_acc = np.empty((0, len(FEATURES)))
y_acc = np.empty(0)

for idx, (month_label, X_m, y_m) in enumerate(monthly_groups):
    X_acc = np.vstack([X_acc, X_m]) if len(X_acc) > 0 else X_m
    y_acc = np.concatenate([y_acc, y_m])

    # Static: never retrain
    # Quarterly: retrain at months 3, 6, 9, ...
    if (idx + 1) % 3 == 0:
        m = retrain(X_acc, y_acc.astype(int), X_sm0, y_sm0, scale0)
        if m: current_models["Quarterly"] = m

    # Monthly: retrain every month
    m = retrain(X_acc, y_acc.astype(int), X_sm0, y_sm0, scale0)
    if m: current_models["Monthly"] = m

    # Weekly: retrain 4 times per month (simulate with 4 sub-batches)
    #   Split the monthly batch into 4 quarters
    n = len(X_m)
    for q in range(4):
        s, e = q * n // 4, (q + 1) * n // 4
        if e > s:
            X_w = np.vstack([X_acc[:-(n - e)], X_m[s:e]]) if n > e else X_acc
            y_w = np.concatenate([y_acc[:-(n - e)], y_m[s:e]]) if n > e else y_acc
            mw  = retrain(X_w, y_w.astype(int), X_sm0, y_sm0, scale0)
            if mw: current_models["Weekly"] = mw

    # Evaluate all policies on fixed eval set
    cadence_results["Month"].append(month_label)
    for policy in ["Static", "Quarterly", "Monthly", "Weekly"]:
        f1, _ = eval_f1_auc(current_models[policy], X_eval, y_eval)
        cadence_results[policy].append(f1)

    print(f"  Month {idx+1:2d} ({month_label}) | "
          f"Static: {cadence_results['Static'][-1]:.4f} | "
          f"Monthly: {cadence_results['Monthly'][-1]:.4f} | "
          f"Weekly: {cadence_results['Weekly'][-1]:.4f}")

# ── 6. Summary table
cad_df = pd.DataFrame(cadence_results)
print("\n" + "="*70)
print("  TABLE — Retraining Cadence Simulation (F1 on 2021–2025 Holdout)")
print("  Insert into Section 6.3 at the [TODO] marker")
print("="*70)
print(cad_df.to_string(index=False))

# ── 7. Summary statistics
print("\nFinal F1 scores (last observation):")
for policy in ["Static", "Quarterly", "Monthly", "Weekly"]:
    final_f1 = cad_df[policy].iloc[-1]
    print(f"  {policy:12s}: {final_f1:.4f}")

# ── 8. Plot
fig, ax = plt.subplots(figsize=(10, 5))
colors = {"Static": "#aaaaaa", "Quarterly": "#4C72B0",
          "Monthly": "#55A868", "Weekly": "#C44E52"}
styles = {"Static": "--", "Quarterly": "-.", "Monthly": "-", "Weekly": "-"}
for policy in ["Static", "Quarterly", "Monthly", "Weekly"]:
    ax.plot(cad_df["Month"], cad_df[policy],
            label=policy, color=colors[policy],
            linestyle=styles[policy], linewidth=2, marker="o", markersize=4)

ax.set_xlabel("Feedback Month", fontsize=11)
ax.set_ylabel("F1-Score (Fixed Holdout)", fontsize=11)
ax.set_title("CARPATCH Retraining Cadence Study\n"
             "F1 vs. Feedback Accumulation (Static / Quarterly / Monthly / Weekly)",
             fontsize=12)
ax.legend(title="Cadence Policy", fontsize=10)
ax.yaxis.set_major_formatter(mticker.FormatStrFormatter("%.3f"))
ax.tick_params(axis="x", rotation=45, labelsize=8)
ax.grid(axis="y", alpha=0.3)
plt.tight_layout()
plt.savefig("cadence_simulation.png", dpi=150, bbox_inches="tight")
plt.show()
print("\n→ Figure saved: cadence_simulation.png")
print("→ Insert table and figure into Section 6.3.")


