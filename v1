    f1_scores = 2 * prec * rec / (prec + rec + 1e-8)
    best_idx  = f1_scores.argmax()
    best_thresh = thresholds[best_idx] if best_idx < len(thresholds) else 1.0
    print(f"{name}: optimal threshold = {best_thresh:.4f}")
    return best_thresh

