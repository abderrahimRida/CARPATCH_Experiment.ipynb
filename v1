The reviewer requests a table showing **how CARPATCH Full's classification performance
(F1, precision, recall, FPR) changes** when the exploitation label threshold changes
from 0.40 → 0.50 → 0.60.

This cell:
1. Rebuilds the exploitation label at each threshold
2. Re-splits, re-applies SMOTE, retrains the full CARPATCH model
3. Evaluates on the corresponding test set
4. Produces **Table X** for insertion into Section 4.1


# ══════════════════════════════════════════════════════════════════════════════
# TASK 1 — EPSS Threshold Sensitivity: Full Performance Table
# Paper Section 4.1  |  Addresses Reviewer comment 2.2.1
# ══════════════════════════════════════════════════════════════════════════════
import numpy as np
import pandas as pd
import xgboost as xgb
from sklearn.model_selection import train_test_split
from sklearn.metrics import (precision_score, recall_score, f1_score,
                              roc_auc_score, confusion_matrix,
                              precision_recall_curve)
from imblearn.over_sampling import SMOTE
import warnings
warnings.filterwarnings('ignore')

RANDOM_STATE = 42
FEATURES = [
    "CVSS_norm", "AC", "NEI", "EAI", "DID", "TTR",
    "CWE_cat", "days_since_patch", "language_enc", "service_tier"
]
TARGET = "exploited"

def best_threshold(y_true, y_prob):
    prec, rec, thresholds = precision_recall_curve(y_true, y_prob)
    f1s = 2 * prec * rec / np.where((prec + rec) == 0, 1, (prec + rec))
    idx = np.argmax(f1s)
    return float(thresholds[min(idx, len(thresholds) - 1)])

def evaluate(name, y_true, y_prob):
    thr   = best_threshold(y_true, y_prob)
    y_pred = (y_prob >= thr).astype(int)
    tn, fp, fn, tp = confusion_matrix(y_true, y_pred, labels=[0, 1]).ravel()
    return {
        "Configuration"  : name,
        "EPSS Threshold" : None,         # filled in loop
        "Positives"      : int(y_true.sum()),
        "Prevalence (%)" : round(float(y_true.mean()) * 100, 2),
        "Precision"      : round(precision_score(y_true, y_pred, zero_division=0), 4),
        "Recall"         : round(recall_score(y_true, y_pred, zero_division=0), 4),
        "F1-Score"       : round(f1_score(y_true, y_pred, zero_division=0), 4),
        "ROC-AUC"        : round(roc_auc_score(y_true, y_prob), 4),
        "FPR"            : round(fp / max(fp + tn, 1), 4),
        "Threshold"      : round(thr, 3),
    }

sensitivity_rows = []

for epss_thr in [0.40, 0.50, 0.60]:
    print(f"\n{'='*60}")
    print(f"  EPSS threshold = {epss_thr}")
    print(f"{'='*60}")

    # ── 1. Rebuild exploitation label at this threshold
    df_run = df_nvd.copy()
    df_run["exploited"] = (
        df_run["cve_id"].isin(kev_set) |
        (df_run["epss_score"] >= epss_thr)
    ).astype(int)

    pos   = int(df_run["exploited"].sum())
    total = len(df_run)
    print(f"  Positives: {pos:,} / {total:,}  ({pos/total*100:.2f}%)")

    # ── 2. Recompute EAI from EPSS (no leakage — EAI derived from EPSS, not label)
    #    The EAI discretisation bins are fixed; only the label changes.
    #    df_nvd['EAI'] is already computed from epss_score — reuse it.

    df_clean_run = df_run[FEATURES + ["exploited"]].dropna()
    X_r = df_clean_run[FEATURES].values
    y_r = df_clean_run["exploited"].values

    if y_r.sum() < 10:
        print(f"  ⚠️  Too few positives at threshold {epss_thr} — skipping.")
        continue

    # ── 3. Split: same 70/15/15 stratified
    X_temp, X_test_r, y_temp, y_test_r = train_test_split(
        X_r, y_r, test_size=0.15, random_state=RANDOM_STATE, stratify=y_r
    )
    X_train_r, X_val_r, y_train_r, y_val_r = train_test_split(
        X_temp, y_temp, test_size=0.1765, random_state=RANDOM_STATE, stratify=y_temp
    )

    # ── 4. SMOTE on training only
    sm = SMOTE(random_state=RANDOM_STATE)
    X_sm, y_sm = sm.fit_resample(X_train_r, y_train_r)

    # ── 5. Train CARPATCH Full model (best hyperparameters from paper)
    scale_pos_r = int((y_train_r == 0).sum() / max((y_train_r == 1).sum(), 1))

    model = xgb.XGBClassifier(
        max_depth=10, learning_rate=0.05, n_estimators=500,
        min_child_weight=1, subsample=0.8, colsample_bytree=0.8,
        scale_pos_weight=scale_pos_r,
        eval_metric="logloss", early_stopping_rounds=20,
        random_state=RANDOM_STATE, verbosity=0,
    )
    model.fit(X_sm, y_sm, eval_set=[(X_val_r, y_val_r)], verbose=False)

    # ── 6. Feedback loop (one retraining cycle — same protocol as main paper)
    val_mask = y_val_r == 1
    X_fb_r = X_val_r[val_mask]
    y_fb_r = y_val_r[val_mask]

    X_retrain_r = np.vstack([X_sm, X_fb_r, X_fb_r, X_fb_r])
    y_retrain_r = np.concatenate([y_sm, y_fb_r, y_fb_r, y_fb_r])

    model_fb = xgb.XGBClassifier(
        max_depth=10, learning_rate=0.05, n_estimators=500,
        min_child_weight=1, subsample=0.8, colsample_bytree=0.8,
        scale_pos_weight=scale_pos_r,
        eval_metric="logloss", early_stopping_rounds=20,
        random_state=RANDOM_STATE, verbosity=0,
    )
    model_fb.fit(X_retrain_r, y_retrain_r,
                 eval_set=[(X_val_r, y_val_r)], verbose=False)

    # ── 7. Evaluate
    probs = model_fb.predict_proba(X_test_r)[:, 1]
    row   = evaluate("CARPATCH Full", y_test_r, probs)
    row["EPSS Threshold"] = epss_thr
    sensitivity_rows.append(row)

    print(f"  Precision : {row['Precision']:.4f}")
    print(f"  Recall    : {row['Recall']:.4f}")
    print(f"  F1-Score  : {row['F1-Score']:.4f}")
    print(f"  ROC-AUC   : {row['ROC-AUC']:.4f}")
    print(f"  FPR       : {row['FPR']:.4f}")

# ── 8. Print final table
sens_df = pd.DataFrame(sensitivity_rows)[[
    "EPSS Threshold", "Positives", "Prevalence (%)",
    "Precision", "Recall", "F1-Score", "ROC-AUC", "FPR"
]]
print("\n" + "="*80)
print("  TABLE X — EPSS Threshold Sensitivity Analysis (CARPATCH Full)")
print("  Insert after Section 4.1 sensitivity paragraph")
print("="*80)
print(sens_df.to_string(index=False))
print("\n→ Copy these values into Table X in Section 4.1 of the paper.")


